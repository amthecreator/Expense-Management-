<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#0a0a0a">
<title>HisaabKitaab</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0a0a0a;--surface:#181818;--surface2:#222;--surface3:#2c2c2c;
  --border:#333;--text:#f0f0f0;--text2:#b0b0b0;--text3:#888;
  --accent:#f5a623;--accent-dim:rgba(245,166,35,0.15);
  --red:#ff5c5c;--red-dim:rgba(255,92,92,0.12);
  --green:#4cde80;--green-dim:rgba(76,222,128,0.12);
  --blue:#5ca8ff;--shadow:0 4px 24px rgba(0,0,0,0.5);
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;max-width:480px;margin:0 auto;overflow-x:hidden;}
.syne{font-family:'Syne',sans-serif;}

/* NAV */
.bottom-nav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;background:#111;border-top:1px solid var(--border);display:flex;z-index:100;padding-bottom:env(safe-area-inset-bottom);}
.nav-btn{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:10px 0 8px;background:none;border:none;cursor:pointer;color:var(--text3);font-family:'DM Sans',sans-serif;position:relative;transition:color .2s;}
.nav-btn.active{color:var(--accent);}
.nav-btn.active::after{content:'';position:absolute;top:0;left:20%;width:60%;height:2px;background:var(--accent);border-radius:0 0 4px 4px;box-shadow:0 0 10px var(--accent);}
.nav-btn span{font-size:20px;}
.nav-btn p{font-size:10px;font-weight:600;margin-top:2px;letter-spacing:.3px;}

/* SCREENS */
.screen{display:none;padding:20px 16px 120px;min-height:100vh;animation:fadeIn .25s ease;}
.screen.active{display:block;}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);}}

/* HEADER */
.page-header{margin-bottom:20px;}
.page-title{font-family:'Syne',sans-serif;font-size:28px;font-weight:800;color:var(--text);letter-spacing:-0.5px;}
.page-tagline{font-size:13px;color:var(--text3);margin-top:3px;}
.greeting{font-size:13px;color:var(--text2);margin-bottom:4px;font-weight:500;}

/* CARDS */
.card{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:22px;margin-bottom:12px;box-shadow:var(--shadow);}
.card-label{font-size:11px;color:var(--text2);font-weight:600;letter-spacing:.8px;text-transform:uppercase;}
.card-value{font-family:'Syne',sans-serif;font-size:36px;font-weight:800;margin-top:4px;}
.card-value.accent{color:var(--accent);}
.card-value.red{color:var(--red);}
.card-value.green{color:var(--green);}

.mini-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px;}
.mini-card{background:var(--surface);border:1px solid var(--border);border-radius:18px;padding:18px;box-shadow:var(--shadow);}
.mini-card .icon{font-size:22px;margin-bottom:8px;}
.mini-card .mlabel{font-size:11px;color:var(--text2);font-weight:600;letter-spacing:.3px;}
.mini-card .val{font-family:'Syne',sans-serif;font-size:22px;font-weight:800;margin-top:4px;}

/* LIST */
.list-item{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:16px;display:flex;align-items:center;gap:12px;margin-bottom:10px;cursor:pointer;transition:all .15s;box-shadow:var(--shadow);}
.list-item:active{transform:scale(0.98);background:var(--surface2);}
.item-icon{width:46px;height:46px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.item-body{flex:1;min-width:0;}
.item-title{font-weight:600;font-size:15px;color:var(--text);}
.item-sub{font-size:12px;color:var(--text2);margin-top:3px;}
.item-right{text-align:right;flex-shrink:0;}
.item-amount{font-family:'Syne',sans-serif;font-weight:700;font-size:17px;}
.item-hint{font-size:10px;color:var(--text3);margin-top:3px;}

.section-title{font-family:'Syne',sans-serif;font-size:12px;font-weight:700;color:var(--text2);margin:20px 0 10px;letter-spacing:1px;text-transform:uppercase;}

/* FAB */
.fab-overlay{display:none;position:fixed;inset:0;z-index:98;background:rgba(0,0,0,.3);}
.fab-overlay.open{display:block;}
.fab-container{position:fixed;bottom:76px;right:calc(50% - 240px + 16px);z-index:99;}
.fab-menu{position:absolute;bottom:62px;right:0;display:none;flex-direction:column;gap:8px;align-items:flex-end;}
.fab-menu.open{display:flex;animation:fadeIn .2s ease;}
.fab-option{background:var(--surface2);border:1px solid var(--border);color:var(--text);border-radius:22px;padding:11px 20px;font-size:14px;font-weight:600;cursor:pointer;white-space:nowrap;box-shadow:var(--shadow);transition:all .15s;font-family:'DM Sans',sans-serif;}
.fab-option:active{transform:scale(0.95);}
.fab-main{background:var(--accent);color:#000;border:none;border-radius:28px;padding:14px 22px;font-size:15px;font-weight:800;font-family:'Syne',sans-serif;cursor:pointer;box-shadow:0 4px 24px rgba(245,166,35,0.5);display:flex;align-items:center;gap:8px;transition:transform .15s;white-space:nowrap;}
.fab-main:active{transform:scale(0.94);}
.fab-icon{font-size:18px;display:inline-block;transition:transform .25s;}

/* MODAL */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.8);z-index:200;align-items:flex-end;justify-content:center;}
.modal-overlay.open{display:flex;}
.modal{background:#161616;border-top:1px solid var(--border);border-radius:28px 28px 0 0;padding:24px 20px 44px;width:100%;max-width:480px;max-height:92vh;overflow-y:auto;animation:slideUp .25s ease;}
@keyframes slideUp{from{transform:translateY(100%);}to{transform:translateY(0);}}
.modal-handle{width:36px;height:4px;background:var(--border);border-radius:2px;margin:0 auto 20px;}
.modal-title{font-family:'Syne',sans-serif;font-size:20px;font-weight:800;margin-bottom:20px;}

/* INPUTS */
.input-group{margin-bottom:14px;}
.input-label{font-size:12px;color:var(--text2);font-weight:600;letter-spacing:.5px;text-transform:uppercase;margin-bottom:7px;display:block;}
input,select{width:100%;background:var(--surface2);color:var(--text);border:1px solid var(--border);border-radius:14px;padding:14px 16px;font-size:16px;font-family:'DM Sans',sans-serif;outline:none;-webkit-appearance:none;transition:border-color .2s;}
input:focus,select:focus{border-color:var(--accent);}
select option{background:#222;}

/* CHIPS */
.chip-row{display:flex;gap:8px;flex-wrap:wrap;}
.chip{background:var(--surface2);border:1px solid var(--border);border-radius:20px;padding:8px 16px;font-size:13px;font-weight:600;cursor:pointer;transition:all .15s;white-space:nowrap;font-family:'DM Sans',sans-serif;color:var(--text2);}
.chip.active{background:var(--accent);border-color:var(--accent);color:#000;}
.chip:active{transform:scale(0.95);}

/* BUTTONS */
.btn-primary{width:100%;background:var(--accent);color:#000;border:none;border-radius:16px;padding:17px;font-size:16px;font-weight:800;font-family:'Syne',sans-serif;cursor:pointer;margin-top:10px;transition:transform .15s;box-shadow:0 4px 16px rgba(245,166,35,0.3);}
.btn-primary:active{transform:scale(0.97);}
.btn-secondary{width:100%;background:var(--surface2);color:var(--text);border:1px solid var(--border);border-radius:16px;padding:15px;font-size:15px;font-weight:600;font-family:'DM Sans',sans-serif;cursor:pointer;margin-top:8px;transition:transform .15s;}
.btn-secondary:active{transform:scale(0.97);}
.btn-danger{background:var(--red-dim)!important;color:var(--red)!important;border:1px solid rgba(255,92,92,0.3)!important;}
.btn-cancel{width:100%;background:none;color:var(--text3);border:none;padding:14px;font-size:15px;cursor:pointer;font-family:'DM Sans',sans-serif;margin-top:4px;}

/* TABS */
.tab-row{display:flex;background:var(--surface);border-radius:14px;padding:4px;margin-bottom:16px;border:1px solid var(--border);}
.tab-item{flex:1;text-align:center;padding:10px;border-radius:11px;cursor:pointer;font-size:13px;font-weight:600;color:var(--text3);transition:all .2s;}
.tab-item.active{background:var(--surface2);color:var(--text);box-shadow:0 2px 8px rgba(0,0,0,0.4);}

/* AVATAR */
.avatar{width:46px;height:46px;border-radius:23px;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:800;font-size:18px;flex-shrink:0;}

/* EMPTY */
.empty{text-align:center;padding:48px 24px;}
.empty .e-icon{font-size:48px;margin-bottom:14px;}
.empty h3{font-family:'Syne',sans-serif;font-size:18px;font-weight:700;color:var(--text);margin-bottom:8px;}
.empty p{font-size:14px;color:var(--text2);margin-bottom:20px;line-height:1.5;}
.empty-btn{background:var(--accent);color:#000;border:none;border-radius:20px;padding:13px 26px;font-size:14px;font-weight:800;font-family:'Syne',sans-serif;cursor:pointer;transition:transform .15s;box-shadow:0 4px 14px rgba(245,166,35,0.35);}
.empty-btn:active{transform:scale(0.95);}

/* TOAST */
.toast{position:fixed;bottom:90px;left:50%;transform:translateX(-50%);background:#222;color:var(--text);border:1px solid var(--border);border-radius:30px;padding:11px 22px;font-size:14px;font-weight:500;z-index:300;opacity:0;transition:opacity .3s;pointer-events:none;white-space:nowrap;box-shadow:var(--shadow);}
.toast.show{opacity:1;}

/* BANK CARDS */
.bank-card{border-radius:20px;padding:20px;display:flex;align-items:center;gap:14px;margin-bottom:10px;transition:all .15s;border:1px solid rgba(255,255,255,0.06);box-shadow:var(--shadow);position:relative;}
.bank-card:active{transform:scale(0.98);}
.bank-card-body{flex:1;}
.bank-card-name{font-family:'Syne',sans-serif;font-weight:800;font-size:16px;color:#fff;}
.bank-card-balance{font-family:'Syne',sans-serif;font-size:26px;font-weight:800;color:#fff;margin-top:2px;}
.dot-menu{position:relative;}
.dot-menu-btn{background:rgba(255,255,255,.1);border:none;color:#fff;font-size:22px;cursor:pointer;padding:6px 10px;border-radius:10px;line-height:1;}
.dot-menu-popup{display:none;position:absolute;right:0;top:42px;background:var(--surface2);border:1px solid var(--border);border-radius:14px;padding:6px;min-width:140px;z-index:50;box-shadow:0 8px 32px rgba(0,0,0,0.6);}
.dot-menu-popup.open{display:block;animation:fadeIn .15s ease;}
.dot-menu-item{padding:10px 14px;border-radius:10px;font-size:14px;font-weight:500;cursor:pointer;display:flex;align-items:center;gap:8px;color:var(--text);}
.dot-menu-item:active{background:var(--surface3);}
.dot-menu-item.danger{color:var(--red);}

/* CATEGORY COLORS */
.cat-food{background:#2a1a0a;}.cat-travel{background:#0a1a2a;}.cat-shopping{background:#1a0a2a;}.cat-recharge{background:#0a2a1a;}.cat-medical{background:#2a0a0a;}.cat-other{background:#1a1a1a;}

/* PIE */
.pie-container{display:flex;align-items:center;gap:20px;padding:4px 0;}
.pie-legend{flex:1;}
.legend-item{display:flex;align-items:center;gap:8px;margin-bottom:8px;}
.legend-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;}
.legend-label{font-size:13px;color:var(--text2);}
.legend-val{font-family:'Syne',sans-serif;font-size:13px;font-weight:700;color:var(--text);margin-left:auto;}

/* WEEKLY */
.weekly-card{background:linear-gradient(135deg,#1c1400,#141414);border:1px solid rgba(245,166,35,0.2);border-radius:18px;padding:18px;margin-bottom:12px;box-shadow:0 4px 20px rgba(245,166,35,0.08);}

/* REMINDER */
.reminder{background:rgba(92,168,255,0.07);border:1px solid rgba(92,168,255,0.2);border-radius:14px;padding:14px 16px;display:flex;align-items:center;gap:12px;margin-bottom:12px;}
.reminder-text{font-size:13px;color:var(--blue);font-weight:500;line-height:1.4;}

/* PARTIAL */
.partial-bar{background:var(--surface3);border-radius:6px;height:5px;margin-top:8px;overflow:hidden;}
.partial-fill{height:100%;border-radius:6px;background:var(--green);transition:width .5s ease;}
.partial-info{display:flex;justify-content:space-between;font-size:11px;color:var(--text2);margin-top:4px;}

/* QUICK ACTIONS */
.quick-actions{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px;}
.quick-btn{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:16px;display:flex;align-items:center;gap:10px;cursor:pointer;transition:all .15s;box-shadow:var(--shadow);}
.quick-btn:active{transform:scale(0.96);}
.quick-btn-text{font-size:14px;font-weight:700;color:var(--text);font-family:'Syne',sans-serif;}

/* BANK COLORS */
.bc0{background:linear-gradient(135deg,#1a2535,#0d1520);}
.bc1{background:linear-gradient(135deg,#1a3525,#0d2015);}
.bc2{background:linear-gradient(135deg,#351a1a,#200d0d);}
.bc3{background:linear-gradient(135deg,#25351a,#15200d);}
.bc4{background:linear-gradient(135deg,#251a35,#150d20);}
.bc5{background:linear-gradient(135deg,#1a2535,#0d1520);}
</style>
</head>
<body>

<!-- HOME -->
<div class="screen active" id="screen-home">
  <div class="page-header">
    <div class="greeting" id="home-greeting"></div>
    <h1 class="page-title syne">HisaabKitaab</h1>
    <div class="page-tagline">Track your money, simply.</div>
  </div>

  <div id="home-reminder"></div>

  <!-- Bank Accounts on Home -->
  <div class="section-title">Your Accounts</div>
  <div id="home-banks"></div>

  <div class="mini-grid" style="margin-top:4px;">
    <div class="mini-card" style="background:#150d0d;">
      <div class="icon">💸</div>
      <div class="mlabel">You Gave</div>
      <div class="val red" id="home-lent">₹0</div>
    </div>
    <div class="mini-card" style="background:#0d150d;">
      <div class="icon">📥</div>
      <div class="mlabel">You Owe</div>
      <div class="val green" id="home-borrowed">₹0</div>
    </div>
  </div>

  <div class="weekly-card">
    <div style="font-size:11px;color:var(--text2);font-weight:600;letter-spacing:.8px;text-transform:uppercase;">This Week's Spending</div>
    <div class="syne" style="font-size:26px;font-weight:800;color:var(--accent);margin-top:4px;" id="home-weekly">₹0</div>
  </div>

  <div class="mini-card" style="margin-bottom:12px;">
    <div style="display:flex;justify-content:space-between;align-items:center;">
      <div>
        <div class="icon">🧾</div>
        <div class="mlabel">Aaj Ka Kharcha</div>
        <div class="val accent" id="home-today" style="font-size:20px;color:var(--accent);">₹0</div>
      </div>
      <div style="text-align:right;">
        <div class="mlabel">Closing Balance</div>
        <div class="syne" style="font-size:18px;font-weight:800;color:var(--text2);" id="home-closing">₹0</div>
      </div>
    </div>
  </div>

  <div class="section-title">Quick Actions</div>
  <div class="quick-actions">
    <div class="quick-btn" onclick="openSpendingModal()">
      <span style="font-size:22px;">➕</span>
      <div class="quick-btn-text">Add Expense</div>
    </div>
    <div class="quick-btn" onclick="openIncomeModal()">
      <span style="font-size:22px;">💰</span>
      <div class="quick-btn-text">Add Income</div>
    </div>
  </div>

  <div class="section-title">Recent Transactions</div>
  <div id="home-recent"></div>
</div>

<!-- BANKS -->
<div class="screen" id="screen-banks">
  <div class="page-header">
    <h1 class="page-title syne">🏦 Banks</h1>
    <div class="page-tagline">Tap to edit · ⋯ to delete</div>
  </div>
  <div class="card" style="text-align:center;">
    <div class="card-label">Total Across All Accounts</div>
    <div class="card-value syne" id="banks-total">₹0</div>
  </div>
  <div id="banks-list"></div>
</div>

<!-- SPENDING -->
<div class="screen" id="screen-spending">
  <div class="page-header">
    <h1 class="page-title syne">🧾 Kharcha</h1>
    <div class="page-tagline">Every rupee tracked</div>
  </div>
  <div class="card" style="text-align:center;background:linear-gradient(135deg,#1a1000,#141414);">
    <div class="card-label">Aaj Ka Total</div>
    <div class="card-value accent" id="spend-today-total">₹0</div>
  </div>
  <div id="spend-pie-section"></div>
  <div class="section-title">All Transactions</div>
  <div id="spend-list"></div>
</div>

<!-- NAV -->
<nav class="bottom-nav">
  <button class="nav-btn active" id="nav-home" onclick="gotoScreen('home')"><span>🏠</span><p>Home</p></button>
  <button class="nav-btn" id="nav-banks" onclick="gotoScreen('banks')"><span>🏦</span><p>Banks</p></button>
  <button class="nav-btn" id="nav-udhar" onclick="gotoScreen('udhar')"><span>🤝</span><p>Udhar</p></button>
  <button class="nav-btn" id="nav-spending" onclick="gotoScreen('spending')"><span>🧾</span><p>Kharcha</p></button>
</nav>

<!-- FAB -->
<div class="fab-overlay" id="fab-overlay" onclick="closeFab()"></div>
<div class="fab-container">
  <div class="fab-menu" id="fab-menu">
    <div class="fab-option" onclick="closeFab();openIncomeModal()">💰 Add Income</div>
    <div class="fab-option" onclick="closeFab();openSpendingModal()">🧾 Add Expense</div>
    <div class="fab-option" onclick="closeFab();openUdharModal()">🤝 Add Udhar</div>
  </div>
  <button class="fab-main" onclick="toggleFab()">
    <span class="fab-icon" id="fab-icon">＋</span>
    <span id="fab-label">Quick Add</span>
  </button>
</div>

<div class="toast" id="toast"></div>

<!-- MODAL: BANK -->
<div class="modal-overlay" id="modal-bank">
  <div class="modal">
    <div class="modal-handle"></div>
    <div class="modal-title" id="bank-modal-title">Add Bank</div>
    <div class="input-group"><label class="input-label">Bank / Account Name</label><input type="text" id="bank-name" placeholder="e.g. SBI, HDFC, Cash, Paytm"/></div>
    <div class="input-group"><label class="input-label">Current Balance (₹)</label><input type="number" id="bank-balance" placeholder="0" inputmode="decimal"/></div>
    <button class="btn-primary" onclick="saveBank()">Save Bank</button>
    <button class="btn-cancel" onclick="closeModal('modal-bank')">Cancel</button>
  </div>
</div>

<!-- MODAL: INCOME -->
<div class="modal-overlay" id="modal-income">
  <div class="modal">
    <div class="modal-handle"></div>
    <div class="modal-title">Add Income 💰</div>
    <div class="input-group"><label class="input-label">Amount (₹)</label><input type="number" id="income-amount" placeholder="0" inputmode="decimal"/></div>
    <div class="input-group"><label class="input-label">To Account</label><div class="chip-row" id="income-bank-chips"></div></div>
    <div class="input-group"><label class="input-label">Note (Optional)</label><input type="text" id="income-note" placeholder="Salary, freelance..."/></div>
    <button class="btn-primary" onclick="saveIncome()">Add Income</button>
    <button class="btn-cancel" onclick="closeModal('modal-income')">Cancel</button>
  </div>
</div>

<!-- MODAL: UDHAR -->
<div class="modal-overlay" id="modal-udhar">
  <div class="modal">
    <div class="modal-handle"></div>
    <div class="modal-title">Add Udhar 🤝</div>
    <div class="input-group">
      <label class="input-label">Type</label>
      <div class="chip-row">
        <div class="chip active" id="udhar-type-lent" onclick="setUdharType('lent')">💸 You Gave</div>
        <div class="chip" id="udhar-type-borrowed" onclick="setUdharType('borrowed')">📥 You Owe</div>
      </div>
    </div>
    <div class="input-group"><label class="input-label">Person Ka Naam</label><input type="text" id="udhar-person" placeholder="Rahul, Priya..."/></div>
    <div class="input-group"><label class="input-label">Amount (₹)</label><input type="number" id="udhar-amount" placeholder="0" inputmode="decimal"/></div>
    <div class="input-group"><label class="input-label">Note (Optional)</label><input type="text" id="udhar-note" placeholder="Kisliye?"/></div>
    <button class="btn-primary" onclick="saveUdhar()">Save</button>
    <button class="btn-cancel" onclick="closeModal('modal-udhar')">Cancel</button>
  </div>
</div>

<!-- MODAL: EDIT UDHAR -->
<div class="modal-overlay" id="modal-edit-udhar">
  <div class="modal">
    <div class="modal-handle"></div>
    <div class="modal-title">Edit Entry ✏️</div>
    <div id="edit-udhar-summary" style="background:var(--surface2);border-radius:14px;padding:16px;margin-bottom:16px;"></div>
    <div class="input-group"><label class="input-label">Updated Remaining Amount (₹)</label><input type="number" id="edit-udhar-amount" placeholder="0" inputmode="decimal"/></div>
    <div class="input-group"><label class="input-label">Note (Optional)</label><input type="text" id="edit-udhar-note" placeholder="Updated note..."/></div>
    <button class="btn-primary" onclick="saveEditUdhar()">Update</button>
    <button class="btn-secondary btn-danger" onclick="settleUdharFull()">✅ Mark Fully Settled</button>
    <button class="btn-cancel" onclick="closeModal('modal-edit-udhar')">Cancel</button>
  </div>
</div>

<!-- MODAL: SPENDING -->
<div class="modal-overlay" id="modal-spending">
  <div class="modal">
    <div class="modal-handle"></div>
    <div class="modal-title">Add Expense 🧾</div>
    <div class="input-group"><label class="input-label">Amount (₹)</label><input type="number" id="spend-amount" placeholder="0" inputmode="decimal"/></div>
    <div class="input-group"><label class="input-label">Category</label><div class="chip-row" id="cat-chips"></div></div>
    <div class="input-group"><label class="input-label">From Account</label><div class="chip-row" id="bank-chips"></div></div>
    <div class="input-group"><label class="input-label">Note (Optional)</label><input type="text" id="spend-note" placeholder="Kya khareeda?"/></div>
    <button class="btn-primary" onclick="saveSpending()">Add Expense</button>
    <button class="btn-cancel" onclick="closeModal('modal-spending')">Cancel</button>
  </div>
</div>

<script>
// ── STORAGE ──────────────────────────────────────────────
const S={
  get:(k,def=[])=>{try{const v=localStorage.getItem(k);return v!==null?JSON.parse(v):def;}catch{return def;}},
  set:(k,v)=>localStorage.setItem(k,JSON.stringify(v))
};

// ── STATE ────────────────────────────────────────────────
let currentScreen='home',currentUdharTab='lent',editBankIndex=null,editUdharId=null;
let selectedCat='Food',selectedBank='',selectedIncomeBank='',selectedUdharType='lent';
let fabOpen=false;

const CATS=[
  {name:'Food',icon:'🍛',cls:'cat-food',color:'#f5a623'},
  {name:'Travel',icon:'🚗',cls:'cat-travel',color:'#5ca8ff'},
  {name:'Shopping',icon:'🛍️',cls:'cat-shopping',color:'#c084fc'},
  {name:'Recharge',icon:'📱',cls:'cat-recharge',color:'#4cde80'},
  {name:'Medical',icon:'💊',cls:'cat-medical',color:'#ff5c5c'},
  {name:'Other',icon:'📦',cls:'cat-other',color:'#aaaaaa'}
];
const AVCOLS=['#f5a623','#5ca8ff','#4cde80','#ff5c5c','#c084fc','#fb923c'];
const BANKCLS=['bc0','bc1','bc2','bc3','bc4','bc5'];

// ── HELPERS ──────────────────────────────────────────────
const fmt=n=>'₹'+parseFloat(n||0).toLocaleString('en-IN',{maximumFractionDigits:0});
const todayStr=()=>new Date().toDateString();
const catInfo=name=>CATS.find(c=>c.name===name)||{icon:'📦',cls:'cat-other',color:'#aaa'};
const avc=name=>AVCOLS[name.charCodeAt(0)%AVCOLS.length];

function countUp(el,target){
  if(!el)return;
  const dur=700,step=16;
  const inc=target/(dur/step);
  let cur=0;
  const t=setInterval(()=>{
    cur+=inc;
    if(cur>=target){cur=target;clearInterval(t);}
    el.textContent=fmt(cur);
  },step);
}

function getGreeting(){
  const h=new Date().getHours();
  if(h<12)return'Good morning 🌅';
  if(h<17)return'Good afternoon ☀️';
  return'Good evening 🌙';
}

// ── NAV ──────────────────────────────────────────────────
function gotoScreen(name){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('screen-'+name).classList.add('active');
  document.getElementById('nav-'+name).classList.add('active');
  currentScreen=name;closeFab();closeDotMenus();
  if(name==='home')renderHome();
  if(name==='banks')renderBanks();
  if(name==='udhar')renderUdhar();
  if(name==='spending')renderSpending();
}

// ── FAB ──────────────────────────────────────────────────
function toggleFab(){
  fabOpen=!fabOpen;
  document.getElementById('fab-menu').classList.toggle('open',fabOpen);
  document.getElementById('fab-overlay').classList.toggle('open',fabOpen);
  document.getElementById('fab-icon').style.transform=fabOpen?'rotate(45deg)':'rotate(0)';
  document.getElementById('fab-label').textContent=fabOpen?'Close':'Quick Add';
}
function closeFab(){
  fabOpen=false;
  document.getElementById('fab-menu').classList.remove('open');
  document.getElementById('fab-overlay').classList.remove('open');
  document.getElementById('fab-icon').style.transform='rotate(0)';
  document.getElementById('fab-label').textContent='Quick Add';
}

// ── MODAL ────────────────────────────────────────────────
function openModal(id){document.getElementById(id).classList.add('open');}
function closeModal(id){document.getElementById(id).classList.remove('open');editBankIndex=null;editUdharId=null;}
document.querySelectorAll('.modal-overlay').forEach(o=>{
  o.addEventListener('click',e=>{if(e.target===o)o.classList.remove('open');});
});

// ── TOAST ────────────────────────────────────────────────
function showToast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg;t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2200);
}

// ── HOME ─────────────────────────────────────────────────
function renderHome(){
  document.getElementById('home-greeting').textContent=getGreeting()+' — here\'s your money today';

  const banks=S.get('banks');
  const udhar=S.get('udhar');
  const spendings=S.get('spendings');

  const lent=udhar.filter(u=>u.type==='lent'&&!u.settled).reduce((s,u)=>s+(+u.remaining||+u.amount),0);
  const borrowed=udhar.filter(u=>u.type==='borrowed'&&!u.settled).reduce((s,u)=>s+(+u.remaining||+u.amount),0);
  const todayTx=spendings.filter(s=>new Date(s.date).toDateString()===todayStr());
  const todaySpent=todayTx.reduce((s,t)=>s+ +t.amount,0);
  const totalBalance=banks.reduce((s,b)=>s+ +b.balance,0);
  const weekAgo=new Date();weekAgo.setDate(weekAgo.getDate()-7);
  const weekSpent=spendings.filter(s=>new Date(s.date)>=weekAgo).reduce((s,t)=>s+ +t.amount,0);

  document.getElementById('home-lent').textContent=fmt(lent);
  document.getElementById('home-borrowed').textContent=fmt(borrowed);
  document.getElementById('home-weekly').textContent=fmt(weekSpent);
  countUp(document.getElementById('home-today'),todaySpent);
  document.getElementById('home-closing').textContent=fmt(totalBalance-todaySpent);

  // Reminder
  const remEl=document.getElementById('home-reminder');
  if(todayTx.length===0&&spendings.length>0){
    remEl.innerHTML=`<div class="reminder"><span style="font-size:20px;">🔔</span><div class="reminder-text">You haven't logged any expense today. Don't forget to track!</div></div>`;
  }else{remEl.innerHTML='';}

  // Bank accounts on home (individual)
  const banksEl=document.getElementById('home-banks');
  if(banks.length===0){
    banksEl.innerHTML=`<div style="background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:18px;margin-bottom:12px;text-align:center;color:var(--text2);font-size:14px;">No accounts added yet. <span style="color:var(--accent);cursor:pointer;font-weight:700;" onclick="gotoScreen('banks')">Add one →</span></div>`;
  }else{
    banksEl.innerHTML=banks.map((b,i)=>`
      <div class="bank-card ${BANKCLS[i%BANKCLS.length]}" onclick="gotoScreen('banks')">
        <span style="font-size:26px;">🏦</span>
        <div class="bank-card-body">
          <div class="bank-card-name">${b.name}</div>
          <div class="bank-card-balance">${fmt(b.balance)}</div>
        </div>
      </div>`).join('');
  }

  // Recent
  const recent=[...spendings].reverse().slice(0,5);
  const el=document.getElementById('home-recent');
  if(recent.length===0){
    el.innerHTML=`<div class="empty">
      <div class="e-icon">💸</div>
      <h3>No transactions yet</h3>
      <p>Start by adding your first transaction to track your money.</p>
      <button class="empty-btn" onclick="openSpendingModal()">+ Add Transaction</button>
    </div>`;
    return;
  }
  el.innerHTML=recent.map(tx=>{
    const c=catInfo(tx.category);
    return`<div class="list-item">
      <div class="item-icon ${c.cls}">${c.icon}</div>
      <div class="item-body">
        <div class="item-title">${tx.category}</div>
        <div class="item-sub">${tx.bank||''} · ${new Date(tx.date).toLocaleDateString('en-IN',{day:'numeric',month:'short'})}</div>
        ${tx.note?`<div class="item-sub">${tx.note}</div>`:''}
      </div>
      <div class="item-right"><div class="item-amount red">-${fmt(tx.amount)}</div></div>
    </div>`;
  }).join('');
}

// ── BANKS ────────────────────────────────────────────────
function renderBanks(){
  const banks=S.get('banks');
  const total=banks.reduce((s,b)=>s+ +b.balance,0);
  countUp(document.getElementById('banks-total'),total);

  const list=document.getElementById('banks-list');
  if(banks.length===0){
    list.innerHTML=`<div class="empty">
      <div class="e-icon">🏦</div>
      <h3>No accounts yet</h3>
      <p>Add your bank accounts to start tracking balances.</p>
      <button class="empty-btn" onclick="openBankModal()">+ Add Bank Account</button>
    </div>`;
    return;
  }
  list.innerHTML=banks.map((b,i)=>`
    <div class="bank-card ${BANKCLS[i%BANKCLS.length]}" onclick="editBank(${i})">
      <span style="font-size:28px;">🏦</span>
      <div class="bank-card-body">
        <div class="bank-card-name">${b.name}</div>
        <div class="bank-card-balance">${fmt(b.balance)}</div>
      </div>
      <div class="dot-menu" onclick="event.stopPropagation();">
        <button class="dot-menu-btn" onclick="toggleDotMenu('dm${i}')">⋯</button>
        <div class="dot-menu-popup" id="dm${i}">
          <div class="dot-menu-item" onclick="closeDotMenus();editBank(${i})">✏️ Edit</div>
          <div class="dot-menu-item danger" onclick="closeDotMenus();deleteBank(${i})">🗑️ Delete</div>
        </div>
      </div>
    </div>`).join('');
}

function toggleDotMenu(id){closeDotMenus();document.getElementById(id)?.classList.toggle('open');}
function closeDotMenus(){document.querySelectorAll('.dot-menu-popup').forEach(m=>m.classList.remove('open'));}
document.addEventListener('click',closeDotMenus);

function openBankModal(){
  editBankIndex=null;
  document.getElementById('bank-modal-title').textContent='Add Bank Account';
  document.getElementById('bank-name').value='';
  document.getElementById('bank-balance').value='';
  openModal('modal-bank');
}
function editBank(i){
  const b=S.get('banks')[i];
  editBankIndex=i;
  document.getElementById('bank-modal-title').textContent='Edit Account';
  document.getElementById('bank-name').value=b.name;
  document.getElementById('bank-balance').value=b.balance;
  openModal('modal-bank');
}
function saveBank(){
  const name=document.getElementById('bank-name').value.trim();
  const balance=parseFloat(document.getElementById('bank-balance').value);
  if(!name||isNaN(balance))return showToast('⚠️ Naam aur balance bharo');
  const banks=S.get('banks');
  if(editBankIndex!==null)banks[editBankIndex]={...banks[editBankIndex],name,balance};
  else banks.push({id:Date.now(),name,balance});
  S.set('banks',banks);
  closeModal('modal-bank');renderBanks();
  showToast('✅ Account saved!');
}
function deleteBank(i){
  if(!confirm('Is account ko hatao?'))return;
  const banks=S.get('banks');banks.splice(i,1);S.set('banks',banks);
  renderBanks();showToast('🗑️ Account deleted');
}

// ── UDHAR ────────────────────────────────────────────────
function switchUdharTab(tab){
  currentUdharTab=tab;
  document.getElementById('tab-lent').classList.toggle('active',tab==='lent');
  document.getElementById('tab-borrowed').classList.toggle('active',tab==='borrowed');
  renderUdhar();
}
function renderUdhar(){
  const all=S.get('udhar');
  const isLent=currentUdharTab==='lent';
  const filtered=all.filter(u=>u.type===currentUdharTab);
  const active=filtered.filter(u=>!u.settled);
  const settled=filtered.filter(u=>u.settled);
  const total=active.reduce((s,u)=>s+(+(u.remaining??u.amount)),0);

  document.getElementById('udhar-total-label').textContent=isLent?'Total You Gave':'Total You Owe';
  const tv=document.getElementById('udhar-total');
  tv.className='card-value '+(isLent?'red':'green');
  countUp(tv,total);

  const el=document.getElementById('udhar-list');
  if(filtered.length===0){
    el.innerHTML=`<div class="empty">
      <div class="e-icon">${isLent?'💸':'📥'}</div>
      <h3>${isLent?'No money given':'Nothing owed'}</h3>
      <p>${isLent?'Track money you lend to others.':'Track money you owe to others.'}</p>
      <button class="empty-btn" onclick="openUdharModal()">+ Add Entry</button>
    </div>`;
    return;
  }

  const renderList=(items,isSettled)=>items.map(u=>{
    const color=avc(u.person);
    const orig=+(u.originalAmount??u.amount);
    const rem=+(u.remaining??u.amount);
    const paid=orig-rem;
    const pct=orig>0?Math.round((paid/orig)*100):0;
    const hasPartial=paid>0&&!isSettled;
    return`<div class="list-item" style="${isSettled?'opacity:0.5':''}" onclick="${isSettled?'':('openEditUdhar(\''+u.id+'\')')}">
      <div class="avatar" style="background:${color}22;color:${color};">${u.person[0].toUpperCase()}</div>
      <div class="item-body">
        <div class="item-title">${u.person}</div>
        <div class="item-sub">${u.note?u.note+' · ':''}${new Date(u.date).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'})}</div>
        ${hasPartial?`<div class="partial-bar"><div class="partial-fill" style="width:${pct}%"></div></div><div class="partial-info"><span>Paid: ${fmt(paid)}</span><span>Left: ${fmt(rem)}</span></div>`:''}
      </div>
      <div class="item-right">
        <div class="item-amount ${isSettled?'':(isLent?'red':'green')}">${fmt(rem)}</div>
        <div class="item-hint">${isSettled?'✅ Settled':'Tap to edit'}</div>
      </div>
    </div>`;
  }).join('');

  el.innerHTML=renderList(active,false)+(settled.length?`<div class="section-title" style="margin-top:16px;">✅ Settled</div>`+renderList(settled,true):'');
}

function openUdharModal(){
  setUdharType(currentUdharTab);
  document.getElementById('udhar-person').value='';
  document.getElementById('udhar-amount').value='';
  document.getElementById('udhar-note').value='';
  openModal('modal-udhar');
}
function setUdharType(type){
  selectedUdharType=type;
  document.getElementById('udhar-type-lent').classList.toggle('active',type==='lent');
  document.getElementById('udhar-type-borrowed').classList.toggle('active',type==='borrowed');
}
function saveUdhar(){
  const person=document.getElementById('udhar-person').value.trim();
  const amount=parseFloat(document.getElementById('udhar-amount').value);
  const note=document.getElementById('udhar-note').value.trim();
  if(!person||isNaN(amount)||amount<=0)return showToast('⚠️ Naam aur amount bharo');
  const all=S.get('udhar');
  all.push({id:String(Date.now()),person,amount,originalAmount:amount,remaining:amount,note,type:selectedUdharType,date:new Date().toISOString(),settled:false});
  S.set('udhar',all);closeModal('modal-udhar');renderUdhar();
  showToast('✅ Udhar saved!');
}
function openEditUdhar(id){
  editUdharId=id;
  const u=S.get('udhar').find(x=>x.id===id);
  if(!u)return;
  const orig=+(u.originalAmount??u.amount);
  const rem=+(u.remaining??u.amount);
  const paid=orig-rem;
  document.getElementById('edit-udhar-summary').innerHTML=`
    <div style="font-family:'Syne',sans-serif;font-size:17px;font-weight:800;margin-bottom:10px;">${u.person}</div>
    <div style="display:flex;gap:16px;flex-wrap:wrap;">
      <div><div style="font-size:11px;color:var(--text2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:2px;">Original</div><div style="font-family:'Syne',sans-serif;font-weight:700;font-size:16px;">${fmt(orig)}</div></div>
      <div><div style="font-size:11px;color:var(--text2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:2px;">Paid so far</div><div style="font-family:'Syne',sans-serif;font-weight:700;font-size:16px;color:var(--green);">${fmt(paid)}</div></div>
      <div><div style="font-size:11px;color:var(--text2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:2px;">Remaining</div><div style="font-family:'Syne',sans-serif;font-weight:700;font-size:16px;color:var(--red);">${fmt(rem)}</div></div>
    </div>
    ${paid>0?`<div class="partial-bar" style="margin-top:12px;"><div class="partial-fill" style="width:${Math.round(paid/orig*100)}%"></div></div>`:'' }`;
  document.getElementById('edit-udhar-amount').value=rem;
  document.getElementById('edit-udhar-note').value=u.note||'';
  openModal('modal-edit-udhar');
}
function saveEditUdhar(){
  const newRem=parseFloat(document.getElementById('edit-udhar-amount').value);
  const note=document.getElementById('edit-udhar-note').value.trim();
  if(isNaN(newRem)||newRem<0)return showToast('⚠️ Valid amount bharo');
  const all=S.get('udhar').map(u=>u.id===editUdharId?{...u,remaining:newRem,note:note||u.note,settled:newRem===0}:u);
  S.set('udhar',all);closeModal('modal-edit-udhar');renderUdhar();
  showToast(newRem===0?'✅ Fully settled!':'✅ Updated!');
}
function settleUdharFull(){
  const all=S.get('udhar').map(u=>u.id===editUdharId?{...u,remaining:0,settled:true}:u);
  S.set('udhar',all);closeModal('modal-edit-udhar');renderUdhar();
  showToast('✅ Settled!');
}

// ── INCOME ───────────────────────────────────────────────
function openIncomeModal(){
  const banks=S.get('banks');
  if(banks.length===0)return showToast('⚠️ Pehle ek bank add karo');
  if(!selectedIncomeBank||!banks.find(b=>b.name===selectedIncomeBank))selectedIncomeBank=banks[0].name;
  document.getElementById('income-bank-chips').innerHTML=banks.map(b=>`<div class="chip ${b.name===selectedIncomeBank?'active':''}" onclick="selIncBank('${b.name}')">${b.name}</div>`).join('');
  document.getElementById('income-amount').value='';
  document.getElementById('income-note').value='';
  openModal('modal-income');
}
function selIncBank(name){
  selectedIncomeBank=name;
  document.querySelectorAll('#income-bank-chips .chip').forEach(c=>c.classList.toggle('active',c.textContent.trim()===name));
}
function saveIncome(){
  const amount=parseFloat(document.getElementById('income-amount').value);
  if(isNaN(amount)||amount<=0)return showToast('⚠️ Amount bharo');
  const banks=S.get('banks').map(b=>b.name===selectedIncomeBank?{...b,balance:+b.balance+amount}:b);
  S.set('banks',banks);closeModal('modal-income');
  if(currentScreen==='home')renderHome();
  if(currentScreen==='banks')renderBanks();
  showToast('💰 Income added!');
}

// ── SPENDING ─────────────────────────────────────────────
function openSpendingModal(){
  const banks=S.get('banks');
  if(banks.length===0)return showToast('⚠️ Pehle ek bank add karo');
  document.getElementById('cat-chips').innerHTML=CATS.map(c=>`<div class="chip ${c.name===selectedCat?'active':''}" onclick="selCat('${c.name}')">${c.icon} ${c.name}</div>`).join('');
  if(!selectedBank||!banks.find(b=>b.name===selectedBank))selectedBank=banks[0].name;
  document.getElementById('bank-chips').innerHTML=banks.map(b=>`<div class="chip ${b.name===selectedBank?'active':''}" onclick="selBank('${b.name}')">${b.name}</div>`).join('');
  document.getElementById('spend-amount').value='';
  document.getElementById('spend-note').value='';
  openModal('modal-spending');
}
function selCat(name){selectedCat=name;document.querySelectorAll('#cat-chips .chip').forEach(c=>c.classList.toggle('active',c.textContent.includes(name)));}
function selBank(name){selectedBank=name;document.querySelectorAll('#bank-chips .chip').forEach(c=>c.classList.toggle('active',c.textContent.trim()===name));}
function saveSpending(){
  const amount=parseFloat(document.getElementById('spend-amount').value);
  const note=document.getElementById('spend-note').value.trim();
  if(isNaN(amount)||amount<=0)return showToast('⚠️ Amount bharo');
  const banks=S.get('banks').map(b=>b.name===selectedBank?{...b,balance:+b.balance-amount}:b);
  S.set('banks',banks);
  const all=S.get('spendings');
  all.push({id:Date.now(),amount,category:selectedCat,bank:selectedBank,note,date:new Date().toISOString()});
  S.set('spendings',all);closeModal('modal-spending');
  if(currentScreen==='spending')renderSpending();
  if(currentScreen==='home')renderHome();
  showToast('✅ Expense saved!');
}
function renderSpending(){
  const all=S.get('spendings');
  const todayTx=all.filter(s=>new Date(s.date).toDateString()===todayStr());
  const todayTotal=todayTx.reduce((s,t)=>s+ +t.amount,0);
  countUp(document.getElementById('spend-today-total'),todayTotal);

  // PIE CHART
  const pieEl=document.getElementById('spend-pie-section');
  const catTotals=CATS.map(c=>({...c,total:todayTx.filter(t=>t.category===c.name).reduce((s,t)=>s+ +t.amount,0)})).filter(c=>c.total>0);
  if(catTotals.length>0&&todayTotal>0){
    let ang=-Math.PI/2;
    const cx=60,cy=60,r=52;
    const paths=catTotals.map(c=>{
      const sl=(c.total/todayTotal)*2*Math.PI;
      const x1=cx+r*Math.cos(ang),y1=cy+r*Math.sin(ang);
      ang+=sl;
      const x2=cx+r*Math.cos(ang),y2=cy+r*Math.sin(ang);
      return`<path d="M${cx},${cy} L${x1.toFixed(2)},${y1.toFixed(2)} A${r},${r} 0 ${sl>Math.PI?1:0},1 ${x2.toFixed(2)},${y2.toFixed(2)} Z" fill="${c.color}" opacity=".9"/>`;
    }).join('');
    const legend=catTotals.map(c=>`<div class="legend-item"><div class="legend-dot" style="background:${c.color}"></div><div class="legend-label">${c.icon} ${c.name}</div><div class="legend-val">${fmt(c.total)}</div></div>`).join('');
    pieEl.innerHTML=`<div class="section-title">Aaj Category-wise</div><div class="card"><div class="pie-container"><svg width="120" height="120" viewBox="0 0 120 120">${paths}</svg><div class="pie-legend">${legend}</div></div></div>`;
  }else{pieEl.innerHTML='';}

  const el=document.getElementById('spend-list');
  if(all.length===0){
    el.innerHTML=`<div class="empty"><div class="e-icon">🧾</div><h3>No expenses yet</h3><p>Start by adding your first transaction 💸</p><button class="empty-btn" onclick="openSpendingModal()">+ Add Transaction</button></div>`;
    return;
  }
  el.innerHTML=[...all].reverse().map(tx=>{
    const c=catInfo(tx.category);
    return`<div class="list-item"><div class="item-icon ${c.cls}">${c.icon}</div><div class="item-body"><div class="item-title">${tx.category}</div><div class="item-sub">${tx.bank} · ${new Date(tx.date).toLocaleDateString('en-IN',{day:'numeric',month:'short'})}</div>${tx.note?`<div class="item-sub">${tx.note}</div>`:''}</div><div class="item-right"><div class="item-amount red">-${fmt(tx.amount)}</div></div></div>`;
  }).join('');
}

// ── INIT ─────────────────────────────────────────────────
renderHome();
</script>
</body>
</html>
